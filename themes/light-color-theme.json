  "tokenColors": [
    // Comments
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#a78bfa",
        "fontStyle": "italic"
      }
    },

    // Doc Comments - slightly deeper
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "punctuation.definition.comment.documentation"
      ],
      "settings": {
        "foreground": "#8b5cf6",
        "fontStyle": "italic"
      }
    },

    // Doc comment tags
    {
      "name": "Doc Comment Tags",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "comment.block.documentation keyword",
        "comment.block.documentation storage.type",
        "keyword.other.documentation",
        "comment.block.documentation punctuation.definition.block.tag"
      ],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "italic"
      }
    },

    // Keywords
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.other.unit",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "italic"
      }
    },

    // Control flow
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch",
        "keyword.control.switch"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },

    // Operators
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.ternary",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#0891b2"
      }
    },

    // Strings
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },

    // String Punctuation
    {
      "name": "String Punctuation",
      "scope": [
        "punctuation.definition.string",
        "string.template punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#047857"
      }
    },

    // Escape characters
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#0891b2",
        "fontStyle": "bold"
      }
    },

    // Template expression punctuation
    {
      "name": "Template Expression Punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },

    // Template expression contents
    {
      "name": "Template Expression",
      "scope": ["meta.template.expression"],
      "settings": {
        "foreground": "#374151"
      }
    },

    // Numbers
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#db2777"
      }
    },

    // Constants
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#db2777",
        "fontStyle": "italic"
      }
    },

    // Functions
    {
      "name": "Function Names",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#d97706"
      }
    },

    // Function parameters
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable",
        "meta.parameters variable"
      ],
      "settings": {
        "foreground": "#374151",
        "fontStyle": "italic"
      }
    },

    // Classes and Types
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },

    // Variables
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#374151"
      }
    },

    // Object Properties
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#374151"
      }
    },

    // Tags (HTML/JSX)
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#db2777"
      }
    },

    // Tag Attributes
    {
      "name": "Tag Attributes",
      "scope": ["entity.other.attribute-name", "meta.tag.attributes"],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "italic"
      }
    },

    // Punctuation
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.section.embedded",
        "punctuation.section.method",
        "punctuation.section.class",
        "punctuation.section.inner-class",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#6b7280"
      }
    },

    // Import/Export
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default",
        "variable.other.meta.import",
        "variable.other.meta.export"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },

    // Destructuring
    {
      "name": "Destructuring",
