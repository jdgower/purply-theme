  "tokenColors": [
    // Comments
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8b7b93",
        "fontStyle": "italic"
      }
    },

    // Doc Comments - slightly brighter than regular comments
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "punctuation.definition.comment.documentation"
      ],
      "settings": {
        "foreground": "#9b8ba8",
        "fontStyle": "italic"
      }
    },

    // Doc comment tags (@param, @returns, etc.)
    {
      "name": "Doc Comment Tags",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "comment.block.documentation keyword",
        "comment.block.documentation storage.type",
        "keyword.other.documentation",
        "comment.block.documentation punctuation.definition.block.tag"
      ],
      "settings": {
        "foreground": "#c4a7e7",
        "fontStyle": "italic"
      }
    },

    // Keywords
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.other.unit",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c678dd",
        "fontStyle": "italic"
      }
    },

    // Control flow - slightly different from other keywords
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch",
        "keyword.control.switch"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },

    // Operators
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.ternary",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },

    // Strings
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },

    // String Punctuation
    {
      "name": "String Punctuation",
      "scope": [
        "punctuation.definition.string",
        "string.template punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },

    // Escape characters in strings
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#56b6c2",
        "fontStyle": "bold"
      }
    },

    // Template expression punctuation (${ })
    {
      "name": "Template Expression Punctuation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },

    // Template expression contents
    {
      "name": "Template Expression",
      "scope": ["meta.template.expression"],
      "settings": {
        "foreground": "#e0def4"
      }
    },

    // Numbers
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },

    // Constants
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#ff79c6",
        "fontStyle": "italic"
      }
    },

    // Functions
    {
      "name": "Function Names",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#61afef"
      }
    },

    // Function parameters
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable",
        "meta.parameters variable"
      ],
      "settings": {
        "foreground": "#e0def4",
        "fontStyle": "italic"
      }
    },

    // Classes and Types
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },

    // Variables
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e0def4"
      }
    },

    // Object Properties
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#e0def4"
      }
    },

    // Tags (HTML/JSX)
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#eb6f92"
      }
    },

    // Tag Attributes
    {
      "name": "Tag Attributes",
      "scope": ["entity.other.attribute-name", "meta.tag.attributes"],
      "settings": {
        "foreground": "#c4a7e7",
        "fontStyle": "italic"
      }
    },

    // Punctuation
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.section.embedded",
        "punctuation.section.method",
        "punctuation.section.class",
        "punctuation.section.inner-class",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#908caa"
      }
    },

    // Import/Export
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
